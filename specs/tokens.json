{
  "$description": "Design token system v1.0.0. Three tiers: prim (raw values, build-time only, never emitted to CSS), sem (meaning-bearing aliases, the only color/space/type surface components may touch), ctx (per-context knobs, including behavioral tokens). The rules block below is not documentation; the token validator reads it as configuration. DTCG-flavored: $type/$value, references in {curly.path} syntax.",
  "version": "1.0.0",

  "rules": {
    "contexts": ["consumer-web", "enterprise-saas"],
    "tiers": {
      "prim": {
        "mayReference": [],
        "componentAccessible": false,
        "emitToCss": false,
        "note": "Primitives are leaves: literal values only, compiled away at build time. They do not exist as custom properties at runtime, so a var(--prim-*) reference in generated CSS resolves to nothing even if it evades validation. The wall is physical, not procedural."
      },
      "sem": {
        "mayReference": ["prim"],
        "componentAccessible": true,
        "emitToCss": true
      },
      "ctx": {
        "mayReference": ["prim"],
        "componentAccessible": true,
        "emitToCss": true
      }
    },
    "completeness": "Every sem token with per-context resolution must define a value for every context in rules.contexts. A missing context resolution is a token-file validation error, caught before any component validates against it. Adding a context means adding a column everywhere, atomically.",
    "emission": "Build emits one block per context: :root[data-context='<name>'] { --sem-*, --ctx-* }. Dimension tokens with densityScaled: true emit as calc(<resolved primitive> * var(--ctx-density-scale)).",
    "contrast": "sem color tokens may declare $extensions['ds.contrastPair']. The accessibility validator resolves each declared pair in every context and requires WCAG 2.1 AA contrast in each independently."
  },

  "prim": {
    "color": {
      "blue":  { "100": { "$type": "color", "$value": "#e8f0fe" }, "300": { "$type": "color", "$value": "#8ab4f8" }, "500": { "$type": "color", "$value": "#3b82f6" }, "600": { "$type": "color", "$value": "#2563eb" }, "700": { "$type": "color", "$value": "#1d4ed8" }, "800": { "$type": "color", "$value": "#1e40af" } },
      "gray":  { "0": { "$type": "color", "$value": "#ffffff" }, "50": { "$type": "color", "$value": "#f8fafc" }, "100": { "$type": "color", "$value": "#f1f5f9" }, "300": { "$type": "color", "$value": "#cbd5e1" }, "500": { "$type": "color", "$value": "#64748b" }, "700": { "$type": "color", "$value": "#334155" }, "900": { "$type": "color", "$value": "#0f172a" } },
      "red":   { "100": { "$type": "color", "$value": "#fee2e2" }, "600": { "$type": "color", "$value": "#dc2626" }, "700": { "$type": "color", "$value": "#b91c1c" } },
      "green": { "100": { "$type": "color", "$value": "#dcfce7" }, "600": { "$type": "color", "$value": "#16a34a" }, "700": { "$type": "color", "$value": "#15803d" } }
    },
    "space": {
      "1": { "$type": "dimension", "$value": "4px" },
      "2": { "$type": "dimension", "$value": "8px" },
      "3": { "$type": "dimension", "$value": "12px" },
      "4": { "$type": "dimension", "$value": "16px" },
      "5": { "$type": "dimension", "$value": "24px" },
      "6": { "$type": "dimension", "$value": "32px" }
    },
    "radius": {
      "none": { "$type": "dimension", "$value": "0px" },
      "sm":   { "$type": "dimension", "$value": "4px" },
      "md":   { "$type": "dimension", "$value": "8px" },
      "lg":   { "$type": "dimension", "$value": "12px" },
      "full": { "$type": "dimension", "$value": "9999px" }
    },
    "type": {
      "family": { "base": { "$type": "fontFamily", "$value": "system-ui, -apple-system, sans-serif" } },
      "size":   { "12": { "$type": "dimension", "$value": "12px" }, "14": { "$type": "dimension", "$value": "14px" }, "16": { "$type": "dimension", "$value": "16px" }, "18": { "$type": "dimension", "$value": "18px" } },
      "weight": { "regular": { "$type": "fontWeight", "$value": 400 }, "medium": { "$type": "fontWeight", "$value": 500 }, "semibold": { "$type": "fontWeight", "$value": 600 } },
      "lineHeight": { "tight": { "$type": "number", "$value": 1.25 }, "base": { "$type": "number", "$value": 1.5 } }
    },
    "motion": {
      "instant": { "$type": "duration", "$value": "0ms" },
      "fast":    { "$type": "duration", "$value": "100ms" },
      "base":    { "$type": "duration", "$value": "200ms" }
    },
    "border": {
      "thin":  { "$type": "dimension", "$value": "1px" },
      "thick": { "$type": "dimension", "$value": "2px" }
    }
  },

  "sem": {
    "color-action-bg": {
      "$type": "color",
      "$extensions": { "ds.contrastPair": "color-action-fg" },
      "resolution": { "consumer-web": "{prim.color.blue.600}", "enterprise-saas": "{prim.color.blue.700}" }
    },
    "color-action-fg": {
      "$type": "color",
      "resolution": "{prim.color.gray.0}"
    },
    "color-action-bg-hover": {
      "$type": "color",
      "resolution": { "consumer-web": "{prim.color.blue.700}", "enterprise-saas": "{prim.color.blue.800}" }
    },
    "color-danger-bg": {
      "$type": "color",
      "$extensions": { "ds.contrastPair": "color-danger-fg" },
      "resolution": { "consumer-web": "{prim.color.red.600}", "enterprise-saas": "{prim.color.red.700}" }
    },
    "color-danger-fg": {
      "$type": "color",
      "resolution": "{prim.color.gray.0}"
    },
    "color-text-primary": {
      "$type": "color",
      "$extensions": { "ds.contrastPair": "color-surface-bg" },
      "resolution": "{prim.color.gray.900}"
    },
    "color-text-secondary": {
      "$type": "color",
      "$extensions": { "ds.contrastPair": "color-surface-bg" },
      "resolution": { "consumer-web": "{prim.color.gray.500}", "enterprise-saas": "{prim.color.gray.700}" }
    },
    "color-text-disabled": {
      "$type": "color",
      "resolution": "{prim.color.gray.300}"
    },
    "color-surface-bg": {
      "$type": "color",
      "resolution": { "consumer-web": "{prim.color.gray.0}", "enterprise-saas": "{prim.color.gray.50}" }
    },
    "color-input-bg": {
      "$type": "color",
      "resolution": "{prim.color.gray.0}"
    },
    "color-input-border": {
      "$type": "color",
      "resolution": { "consumer-web": "{prim.color.gray.300}", "enterprise-saas": "{prim.color.gray.500}" }
    },
    "color-input-border-focus": {
      "$type": "color",
      "resolution": "{prim.color.blue.600}"
    },
    "color-focus-ring": {
      "$type": "color",
      "resolution": "{prim.color.blue.300}"
    },
    "color-feedback-error": {
      "$type": "color",
      "$extensions": { "ds.contrastPair": "color-surface-bg" },
      "resolution": "{prim.color.red.700}"
    },
    "color-feedback-success": {
      "$type": "color",
      "$extensions": { "ds.contrastPair": "color-surface-bg" },
      "resolution": "{prim.color.green.700}"
    },
    "color-emphasis-bg": {
      "$type": "color",
      "$extensions": { "ds.contrastPair": "color-emphasis-fg" },
      "resolution": { "consumer-web": "{prim.color.blue.100}", "enterprise-saas": "{prim.color.gray.100}" }
    },
    "color-emphasis-fg": {
      "$type": "color",
      "resolution": { "consumer-web": "{prim.color.blue.800}", "enterprise-saas": "{prim.color.gray.700}" }
    },

    "space-inset-control": {
      "$type": "dimension",
      "densityScaled": true,
      "resolution": "{prim.space.3}"
    },
    "space-inset-container": {
      "$type": "dimension",
      "densityScaled": true,
      "resolution": "{prim.space.4}"
    },
    "space-gap-related": {
      "$type": "dimension",
      "densityScaled": true,
      "resolution": "{prim.space.2}"
    },
    "space-gap-stack": {
      "$type": "dimension",
      "densityScaled": true,
      "resolution": "{prim.space.4}"
    },

    "radius-interactive": {
      "$type": "dimension",
      "resolution": { "consumer-web": "{prim.radius.lg}", "enterprise-saas": "{prim.radius.sm}" }
    },
    "radius-container": {
      "$type": "dimension",
      "resolution": { "consumer-web": "{prim.radius.lg}", "enterprise-saas": "{prim.radius.md}" }
    },

    "type-control": {
      "$type": "typography",
      "resolution": {
        "consumer-web":    { "family": "{prim.type.family.base}", "size": "{prim.type.size.16}", "weight": "{prim.type.weight.medium}", "lineHeight": "{prim.type.lineHeight.tight}" },
        "enterprise-saas": { "family": "{prim.type.family.base}", "size": "{prim.type.size.14}", "weight": "{prim.type.weight.medium}", "lineHeight": "{prim.type.lineHeight.tight}" }
      }
    },
    "type-body": {
      "$type": "typography",
      "resolution": {
        "consumer-web":    { "family": "{prim.type.family.base}", "size": "{prim.type.size.16}", "weight": "{prim.type.weight.regular}", "lineHeight": "{prim.type.lineHeight.base}" },
        "enterprise-saas": { "family": "{prim.type.family.base}", "size": "{prim.type.size.14}", "weight": "{prim.type.weight.regular}", "lineHeight": "{prim.type.lineHeight.base}" }
      }
    },
    "type-label": {
      "$type": "typography",
      "resolution": {
        "consumer-web":    { "family": "{prim.type.family.base}", "size": "{prim.type.size.14}", "weight": "{prim.type.weight.medium}", "lineHeight": "{prim.type.lineHeight.tight}" },
        "enterprise-saas": { "family": "{prim.type.family.base}", "size": "{prim.type.size.12}", "weight": "{prim.type.weight.semibold}", "lineHeight": "{prim.type.lineHeight.tight}" }
      }
    },
    "type-caption": {
      "$type": "typography",
      "resolution": { "family": "{prim.type.family.base}", "size": "{prim.type.size.12}", "weight": "{prim.type.weight.regular}", "lineHeight": "{prim.type.lineHeight.base}" }
    },

    "border-control": {
      "$type": "dimension",
      "resolution": { "consumer-web": "{prim.border.thin}", "enterprise-saas": "{prim.border.thin}" }
    },
    "border-focus": {
      "$type": "dimension",
      "resolution": "{prim.border.thick}"
    }
  },

  "ctx": {
    "consumer-web": {
      "density-scale":    { "$type": "number", "$value": 1 },
      "motion-duration":  { "$type": "duration", "resolution": "{prim.motion.base}" },
      "validation-mode":  { "$type": "string", "$value": "lazy", "behavioral": true, "note": "Components read this via the context attribute, not CSS. lazy: validate on submit. Consumer contexts forgive in-progress input." },
      "disclosure-mode":  { "$type": "string", "$value": "progressive", "behavioral": true, "note": "Molecules may collapse secondary affordances behind interaction." }
    },
    "enterprise-saas": {
      "density-scale":    { "$type": "number", "$value": 0.85 },
      "motion-duration":  { "$type": "duration", "resolution": "{prim.motion.fast}" },
      "validation-mode":  { "$type": "string", "$value": "eager", "behavioral": true, "note": "eager: validate on blur. Enterprise contexts surface errors immediately." },
      "disclosure-mode":  { "$type": "string", "$value": "full", "behavioral": true, "note": "Everything visible. Information density is the point." }
    }
  }
}
